---
import { site } from '@/config';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t" style="border-color: var(--border);">
  <div class="container-content flex flex-col items-start justify-between gap-6 py-10 sm:flex-row sm:items-center">
    <p class="text-caption" style="color: var(--text-muted);">
      © {year} {site.name}. Built with Astro & hosted on GitHub Pages.
    </p>
    <SocialLinks />
  </div>
</footer>
