---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { url } from '@/lib/url';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, updatedDate, tags } = post.data;
---

<BaseLayout title={title} description={description} type="article">
  <article class="container-content pb-section pt-12 md:pb-section-lg md:pt-20">
    <a href={url('/blog')} class="text-caption uppercase tracking-widest" style="color: var(--accent);">
      ← All posts
    </a>

    <header class="mt-6">
      <time class="text-caption uppercase tracking-widest" style="color: var(--text-muted);" datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        {updatedDate && ` · Updated ${updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}`}
      </time>
      <h1 class="mt-3 font-display text-display-lg font-semibold">{title}</h1>
      {tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {tags.map((t) => (
            <li class="rounded-btn border px-2 py-0.5 text-caption" style="border-color: var(--border); color: var(--text-muted);">
              #{t}
            </li>
          ))}
        </ul>
      )}
    </header>

    <div class="prose-site mx-auto mt-10 max-w-3xl">
      <Content />
    </div>
  </article>
</BaseLayout>
