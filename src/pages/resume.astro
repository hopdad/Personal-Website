---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TechBadge from '@/components/TechBadge.astro';
import { site } from '@/config';
import resume from '@/data/resume';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: resume.headline,
  email: `mailto:${site.email}`,
  url: Astro.site?.toString(),
  sameAs: [site.social.github, site.social.linkedin],
};
---

<BaseLayout
  title="Resume"
  description={`Resume of ${site.name} \u2014 ${resume.headline}`}
  jsonLd={jsonLd}
>
  <section class="container-content pb-section pt-16 md:pb-section-lg md:pt-24">
    <p class="mb-4 text-caption uppercase tracking-widest" style="color: var(--accent);">
      Resume
    </p>
    <h1 class="font-display text-display-lg font-semibold">{site.name}</h1>
    <p class="mt-2 text-heading-md" style="color: var(--text-muted);">{resume.headline}</p>
    {resume.summary && (
      <p class="mt-6 max-w-3xl text-body-lg" style="color: var(--text-muted);">
        {resume.summary}
      </p>
    )}
  </section>

  <!-- Experience -->
  <section class="container-content pb-section md:pb-section-lg">
    <h2 class="mb-10 font-display text-heading-lg">Experience</h2>
    <ol class="space-y-10">
      {resume.experience.map((job, i) => (
        <li
          class:list={['pb-10', { 'border-b': i < resume.experience.length - 1 }]}
          style="border-color: var(--border);"
        >
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <div>
              <h3 class="font-display text-heading-md">{job.title}</h3>
              <p class="text-body" style="color: var(--text-muted);">
                {job.company}{job.location && ` \u00b7 ${job.location}`}
              </p>
            </div>
            <p class="mt-1 shrink-0 text-caption sm:mt-0" style="color: var(--text-muted);">
              {job.startDate} \u2014 {job.endDate ?? 'Present'}
            </p>
          </div>
          <ul class="mt-4 list-disc space-y-1.5 pl-5 text-body" style="color: var(--text-muted);">
            {job.highlights.map((h) => <li>{h}</li>)}
          </ul>
        </li>
      ))}
    </ol>
  </section>

  <!-- Skills -->
  <section class="container-content pb-section md:pb-section-lg">
    <h2 class="mb-10 font-display text-heading-lg">Skills</h2>
    <div class="grid gap-8 sm:grid-cols-2">
      {resume.skills.map((group) => (
        <div>
          <h3 class="mb-3 text-caption uppercase tracking-widest" style="color: var(--accent);">
            {group.category}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li><TechBadge label={item} /></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Education -->
  <section class="container-content pb-section md:pb-section-lg">
    <h2 class="mb-10 font-display text-heading-lg">Education</h2>
    <ol class="space-y-8">
      {resume.education.map((edu) => (
        <li>
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <div>
              <h3 class="font-display text-heading-md">{edu.degree}</h3>
              <p class="text-body" style="color: var(--text-muted);">
                {edu.school}{edu.location && ` \u00b7 ${edu.location}`}
              </p>
            </div>
            <p class="mt-1 shrink-0 text-caption sm:mt-0" style="color: var(--text-muted);">
              {edu.startDate} \u2014 {edu.endDate}
            </p>
          </div>
          {edu.honors && (
            <p class="mt-2 text-body" style="color: var(--text-muted);">{edu.honors}</p>
          )}
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
